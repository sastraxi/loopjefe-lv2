@prefix lv2:    <http://lv2plug.in/ns/lv2core#>.
@prefix modgui: <http://moddevices.com/ns/modgui#>.

<http://treefallsound.com/plugins/loopjefe-2x2>
  modgui:gui [
    modgui:resourcesDirectory <modgui>;
    modgui:iconTemplate <modgui/icon-loopjefe.html>;
    modgui:stylesheet <modgui/stylesheet-loopjefe.css>;
    modgui:screenshot <modgui/screenshot-loopjefe.png>;
    modgui:thumbnail <modgui/thumbnail-loopjefe.png>;
    modgui:port [
      lv2:index 0;
      lv2:symbol "state";
      lv2:name "State";
    ];
    modgui:monitoredOutputs [
      lv2:symbol "state";
    ] , [
      lv2:symbol "measure_number";
    ];
  ].
