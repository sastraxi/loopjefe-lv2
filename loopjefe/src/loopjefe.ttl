@prefix atom:   <http://lv2plug.in/ns/ext/atom#>.
@prefix doap:   <http://usefulinc.com/ns/doap#>.
@prefix foaf:   <http://xmlns.com/foaf/0.1/>.
@prefix lv2:    <http://lv2plug.in/ns/lv2core#>.
@prefix mod:    <http://moddevices.com/ns/mod#>.
@prefix pprops: <http://lv2plug.in/ns/ext/port-props#>.
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#>.
@prefix time:   <http://lv2plug.in/ns/ext/time#>.
@prefix urid:   <http://lv2plug.in/ns/ext/urid#>.

<http://treefallsound.com/plugins/loopjefe>
a lv2:Plugin, lv2:UtilityPlugin;

doap:name "LoopJefe";
doap:license <http://usefulinc.com/doap/licenses/gpl>;

doap:developer [
    foaf:name "Jesse Chappell";
    foaf:homepage <http://essej.net/sooperlooper/oldplugin.html>;
    foaf:mbox <mailto:jesse@essej.net>;
];

doap:maintainer [
    foaf:name "TreeFallSound";
    foaf:homepage <https://github.com/sastraxi/loopjefe-lv2>;
];

mod:brand "TreeFallSound";
mod:label "LoopJefe";

lv2:requiredFeature urid:map;

lv2:minorVersion 0;
lv2:microVersion 1;
rdfs:comment """
Beat-synced looping plugin, forked from SooperLooper for the pi-Stomp multitrack looper workflow
""";

lv2:port [
  a lv2:AudioPort, lv2:InputPort;
  lv2:index 0;
  lv2:symbol "input";
  lv2:name "Input";
  lv2:shortName "Input";
],
[
  a lv2:AudioPort, lv2:OutputPort;
  lv2:index 1;
  lv2:symbol "output";
  lv2:name "Output";
  lv2:shortName "Output";
],
[
  a lv2:ControlPort, lv2:OutputPort;
  lv2:index 2;
  lv2:symbol "state";
  lv2:name "State";
  lv2:shortName "State";
  lv2:default 0;
  lv2:minimum 0;
  lv2:maximum 8;
  lv2:portProperty lv2:integer, lv2:enumeration;
  lv2:scalePoint [ rdfs:label "Empty";         rdf:value 0 ];
  lv2:scalePoint [ rdfs:label "Record Arm";    rdf:value 1 ];
  lv2:scalePoint [ rdfs:label "Recording";     rdf:value 2 ];
  lv2:scalePoint [ rdfs:label "Record Close";  rdf:value 3 ];
  lv2:scalePoint [ rdfs:label "Playback";      rdf:value 4 ];
  lv2:scalePoint [ rdfs:label "Stopped";       rdf:value 5 ];
  lv2:scalePoint [ rdfs:label "Overdub Arm";   rdf:value 6 ];
  lv2:scalePoint [ rdfs:label "Overdub";       rdf:value 7 ];
  lv2:scalePoint [ rdfs:label "Overdub Close"; rdf:value 8 ];
],
[
  a lv2:ControlPort, lv2:OutputPort;
  lv2:index 3;
  lv2:symbol "measure_number";
  lv2:name "Measure Number";
  lv2:shortName "Measure";
  lv2:default 0;
  lv2:minimum 0;
  lv2:portProperty lv2:integer;
],
[
  a lv2:ControlPort, lv2:InputPort;
  lv2:index 4;
  lv2:symbol "advance";
  lv2:name "Advance";
  lv2:shortName "Advance";
  lv2:default 0;
  lv2:minimum 0;
  lv2:maximum 1;
  lv2:portProperty lv2:integer, lv2:toggled, pprops:trigger;
],
[
  a lv2:ControlPort, lv2:InputPort;
  lv2:index 5;
  lv2:symbol "reset";
  lv2:name "Reset";
  lv2:shortName "Reset";
  lv2:default 0;
  lv2:minimum 0;
  lv2:maximum 1;
  lv2:portProperty lv2:integer, lv2:toggled, pprops:trigger;
],
[
  a lv2:ControlPort, lv2:InputPort;
  lv2:index 6;
  lv2:symbol "undo";
  lv2:name "Undo";
  lv2:shortName "Undo";
  lv2:default 0;
  lv2:minimum 0;
  lv2:maximum 1;
  lv2:portProperty lv2:integer, lv2:toggled, pprops:trigger;
],
[
  a lv2:ControlPort, lv2:InputPort;
  lv2:index 7;
  lv2:symbol "redo";
  lv2:name "Redo";
  lv2:shortName "Redo";
  lv2:default 0;
  lv2:minimum 0;
  lv2:maximum 1;
  lv2:portProperty lv2:integer, lv2:toggled, pprops:trigger;
],
[
  a lv2:ControlPort, lv2:InputPort;
  lv2:index 8;
  lv2:symbol "dryLevel";
  lv2:name "Dry Level";
  lv2:shortName "Dry Level";
  lv2:default 1.0;
  lv2:minimum 0.0;
  lv2:maximum 1.0;
],
[
  a atom:AtomPort, lv2:InputPort;
  lv2:index 9;
  lv2:symbol "time_info";
  lv2:name "Time Info";
  lv2:shortName "Time Info";
  atom:bufferType atom:Sequence;
  atom:supports time:Position;
].
